OPENAI_API_KEY=sk-...

# Substring usado para localizar el dispositivo VB-CABLE (case-insensitive).
# Por defecto "cable output". Cámbialo si Windows renombra el dispositivo.
CABLE_HINT=cable output

# Substring del micrófono del operador. Si se deja vacío, se usa el
# dispositivo de entrada por defecto del sistema.
OPERATOR_MIC_HINT=

# Google Maps Geocoding API key (opcional).
# Si se deja vacío, la normalización de dirección de RECOGIDA queda desactivada.
# Pasos: Google Cloud Console → habilitar Geocoding API → crear API key → activar billing.
# Free tier: 10.000 geocodings/mes. Luego $5 por cada 1.000 (tramo 10k-100k).
# Poner cuota diaria conservadora (~500/día) y budget alert ($10/mes) en Cloud Console.
GOOGLE_MAPS_API_KEY=

# Centralización de sesiones en Google Drive + Sheets (opcional).
# Si ambas están vacías, las sesiones solo se guardan localmente.
# Ver docs/SETUP_CLOUD.md para instrucciones de configuración paso a paso.
CLOUD_WEBHOOK_URL=
CLOUD_WEBHOOK_TOKEN=
